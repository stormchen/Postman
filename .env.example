# Mantis Bug Tracker API 設定
# 請將此檔案複製為 .env，並填入實際的值

# Mantis API Token
# 從 Mantis 帳戶設定中取得 API Token
TOKEN=your_api_token_here

# Mantis Account ID (可選)
# 如果 API 要求 Account ID，請填入此欄位
ACCOUNTID=your_account_id_here

# SMTP 設定
# 用於發送報表至 Teams 頻道的電子郵件
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SENDER_EMAIL=sender@example.com
TEAMS_CHANNEL_EMAIL=your_teams_channel_email@domain.com
