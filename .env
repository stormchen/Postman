# Mantis Bug Tracker API 設定
# 請將此檔案複製為 .env，並填入實際的值

# Mantis API Token
# 從 Mantis 帳戶設定中取得 API Token
TOKEN=uzFOx4kdS_OulFgjJqvUuAvSGFraiSXm

# Mantis Account ID (可選)
# 如果 API 要求 Account ID，請填入此欄位
ACCOUNTID=stormchen

# SMTP 設定
# 用於發送報表至 Teams 頻道的電子郵件
# SMTP_SERVER=10.210.2.21
SMTP_SERVER=10.1.1.200
SMTP_PORT=25
SENDER_EMAIL=storm.chen@gigacomputing.com
TEAMS_CHANNEL_EMAIL=storm.chen@gigacomputing.com